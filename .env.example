# ============================================================
# tiny-forum 环境变量配置（复制为 .env 并填写真实值）
# ============================================================

# ---------- 数据库 ----------
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=tiny_forum
# DB_PORT=54321

# # ---------- Redis ----------
# REDIS_PORT=63791

# # ---------- 后端 ----------
# BACKEND_PORT=8081
# SERVER_MODE=release          # debug | release

# # ---------- JWT ----------
# JWT_SECRET=tiny-forum-secret-change-in-production-32chars

# # ---------- 邮件（可选） ----------
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USERNAME=noreply@example.com
# EMAIL_PASSWORD=your-email-password

# # ---------- Nginx 端口 ----------
# HTTP_PORT=8080          # 改为 8080，避免特权端口
# HTTPS_PORT=8443         # 改为 8443

# # ---------- CDN / 上传（可选） ----------
# CDN_DOMAIN=https://cdn.example.com

# # ---------- 管理员初始账号（可选，首次部署用） ----------
# ADMIN_EMAIL=admin@test.com
# ADMIN_PASSWORD=password
# ADMIN_USERNAME=admin