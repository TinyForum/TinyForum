# .env 文件示例
# 数据库配置
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=tiny_forum
DB_PORT=5432

# Redis 配置
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379

# 应用配置
APP_ENV=production
APP_SECRET=your_app_secret_key
BACKEND_PORT=8080

# JWT 配置
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRE_HOURS=24

# 前端配置
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
FRONTEND_PORT=3000
NODE_ENV=production

# Nginx 配置
HTTP_PORT=80
HTTPS_PORT=443

# 数据库管理工具
ADMINER_PORT=8081

# 资源限制（可选）
GO_VERSION=1.21
NODE_VERSION=20
LOG_LEVEL=info