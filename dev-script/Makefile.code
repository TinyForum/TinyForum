# ============================================
# 代码检查与格式化
# ============================================

.PHONY: fmt lint test ci check-tools
.PHONY: fmt-backend fmt-frontend lint-backend lint-frontend type-check
.PHONY: test-backend test-frontend fix fix-frontend

# 颜色输出
RED    := \033[0;31m
GREEN  := \033[0;32m
YELLOW := \033[1;33m
BLUE   := \033[0;34m
NC     := \033[0m

# 检测工具是否存在
HAS_GO      := $(shell command -v go 2>/dev/null)
HAS_GOLANGCI := $(shell command -v golangci-lint 2>/dev/null)
HAS_PNPM    := $(shell command -v pnpm 2>/dev/null)
HAS_NPM     := $(shell command -v npm 2>/dev/null)
HAS_PRETTIER := $(shell cd frontend && pnpm exec prettier --version 2>/dev/null)

# 包管理器检测（优先 pnpm，降级 npm）
PACKAGE_MANAGER := $(if $(HAS_PNPM),pnpm,$(if $(HAS_NPM),npm,echo none))

# ============================================
# 格式化
# ============================================

fmt: fmt-backend fmt-frontend
	@echo "$(GREEN)✅ 所有代码格式化完成$(NC)"

fmt-backend:
	@echo "$(BLUE)📦 格式化 Go 代码...$(NC)"
	@cd backend && go fmt ./...
	@echo "$(GREEN)   ✅ Go 代码格式化完成$(NC)"

fmt-frontend:
	@echo "$(BLUE)📦 格式化前端代码...$(NC)"
	@if [ "$(PACKAGE_MANAGER)" != "none" ]; then \
		cd frontend && $(PACKAGE_MANAGER) run fmt 2>/dev/null || \
		(cd frontend && npx prettier --write 'src/**/*.{ts,tsx,css}' 2>/dev/null); \
		echo "$(GREEN)   ✅ 前端代码格式化完成$(NC)"; \
	else \
		echo "$(YELLOW)   ⚠️  跳过前端格式化 (未找到 pnpm/npm)$(NC)"; \
	fi

# ============================================
# 代码检查
# ============================================

lint: lint-backend lint-frontend type-check
	@echo "$(GREEN)✅ 所有代码检查通过$(NC)"

lint-backend:
	@echo "$(BLUE)🔍 检查 Go 代码...$(NC)"
	@if [ -n "$(HAS_GOLANGCI)" ]; then \
		cd backend && golangci-lint run ./...; \
		if [ $$? -eq 0 ]; then \
			echo "$(GREEN)   ✅ Go 代码检查通过$(NC)"; \
		else \
			echo "$(RED)   ❌ Go 代码检查失败$(NC)"; \
			exit 1; \
		fi \
	else \
		echo "$(YELLOW)   ⚠️  golangci-lint 未安装$(NC)"; \
		echo "   💡 安装: brew install golangci-lint (macOS)"; \
	fi

lint-frontend:
	@echo "$(BLUE)🔍 检查前端代码...$(NC)"
	@if [ "$(PACKAGE_MANAGER)" != "none" ]; then \
		cd frontend && $(PACKAGE_MANAGER) run lint 2>/dev/null; \
		if [ $$? -eq 0 ]; then \
			echo "$(GREEN)   ✅ 前端代码检查通过$(NC)"; \
		else \
			echo "$(YELLOW)   ⚠️  前端代码检查有警告$(NC)"; \
		fi \
	else \
		echo "$(YELLOW)   ⚠️  跳过前端检查 (未找到 pnpm/npm)$(NC)"; \
	fi

type-check:
	@echo "$(BLUE)🔍 TypeScript 类型检查...$(NC)"
	@if [ "$(PACKAGE_MANAGER)" != "none" ]; then \
		cd frontend && $(PACKAGE_MANAGER) run type-check 2>/dev/null || \
		(cd frontend && npx tsc --noEmit 2>/dev/null); \
		if [ $$? -eq 0 ]; then \
			echo "$(GREEN)   ✅ 类型检查通过$(NC)"; \
		else \
			echo "$(YELLOW)   ⚠️  类型检查有错误$(NC)"; \
		fi \
	else \
		echo "$(YELLOW)   ⚠️  跳过类型检查 (未找到 pnpm/npm)$(NC)"; \
	fi

# ============================================
# 测试
# ============================================

test-project: test-backend test-frontend
	@echo "$(GREEN)✅ 所有测试完成$(NC)"

test-backend:
	@echo "$(BLUE)🧪 运行后端测试...$(NC)"
	@cd backend && go test -cover ./... 2>&1 | grep -E "(ok|FAIL|coverage)" || true
	@echo "$(GREEN)   ✅ 后端测试完成$(NC)"

test-frontend:
	@echo "$(BLUE)🧪 运行前端测试...$(NC)"
	@if [ "$(PACKAGE_MANAGER)" != "none" ]; then \
		cd frontend && $(PACKAGE_MANAGER) test -- --coverage 2>/dev/null || \
		cd frontend && $(PACKAGE_MANAGER) test 2>/dev/null; \
		echo "$(GREEN)   ✅ 前端测试完成$(NC)"; \
	else \
		echo "$(YELLOW)   ⚠️  跳过前端测试 (未找到 pnpm/npm)$(NC)"; \
	fi

# ============================================
# 自动修复
# ============================================

fix: fix-frontend
	@echo "$(GREEN)✅ 自动修复完成$(NC)"

fix-frontend:
	@echo "$(BLUE)🔧 自动修复前端代码...$(NC)"
	@if [ "$(PACKAGE_MANAGER)" != "none" ]; then \
		cd frontend && $(PACKAGE_MANAGER) run lint:fix 2>/dev/null || \
		(cd frontend && npx eslint . --ext .ts,.tsx --fix 2>/dev/null); \
		echo "$(GREEN)   ✅ 前端代码修复完成$(NC)"; \
	else \
		echo "$(YELLOW)   ⚠️  跳过 (未找到 pnpm/npm)$(NC)"; \
	fi

# ============================================
# CI 完整检查
# ============================================

ci: check-tools fmt lint test
	@echo ""
	@echo "$(GREEN)╔════════════════════════════════════════════════════════════════╗$(NC)"
	@echo "$(GREEN)║                    ✅ CI 检查全部通过！                         ║$(NC)"
	@echo "$(GREEN)╚════════════════════════════════════════════════════════════════╝$(NC)"

# ============================================
# 工具检测
# ============================================

check-tools:
	@echo "$(BLUE)🔧 检查开发工具...$(NC)"
	@echo "  Go:          $(if $(HAS_GO),$(GREEN)✅$(NC),$(RED)❌ 未安装$(NC))"
	@echo "  golangci-lint: $(if $(HAS_GOLANGCI),$(GREEN)✅$(NC),$(YELLOW)⚠️  未安装$(NC))"
	@echo "  pnpm/npm:    $(if $(PACKAGE_MANAGER),$(GREEN)✅ $(PACKAGE_MANAGER)$(NC),$(RED)❌ 未安装$(NC))"
	@echo "  prettier:    $(if $(HAS_PRETTIER),$(GREEN)✅$(NC),$(YELLOW)⚠️  未安装$(NC))"
	@echo ""

# ============================================
# 帮助
# ============================================

code-help:
	@echo "代码检查与格式化命令:"
	@echo ""
	@echo "  $(GREEN)make fmt$(NC)            - 格式化所有代码"
	@echo "  $(GREEN)make lint$(NC)           - 检查所有代码"
	@echo "  $(GREEN)make test$(NC)           - 运行所有测试"
	@echo "  $(GREEN)make ci$(NC)             - CI 完整检查 (fmt + lint + test)"
	@echo "  $(GREEN)make fix$(NC)            - 自动修复前端代码问题"
	@echo ""
	@echo "  $(GREEN)make check-tools$(NC)    - 检查开发工具是否安装"
	@echo "  $(GREEN)make fmt-backend$(NC)    - 仅格式化后端"
	@echo "  $(GREEN)make fmt-frontend$(NC)   - 仅格式化前端"
	@echo "  $(GREEN)make lint-backend$(NC)   - 仅检查后端"
	@echo "  $(GREEN)make lint-frontend$(NC)  - 仅检查前端"
	@echo "  $(GREEN)make test-backend$(NC)   - 仅运行后端测试"
	@echo "  $(GREEN)make test-frontend$(NC)  - 仅运行前端测试"
	@echo ""
	@echo "安装依赖:"
	@echo "  brew install golangci-lint     # macOS 安装 Go linter"
	@echo "  cd frontend && pnpm install    # 安装前端依赖"