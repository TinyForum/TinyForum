# ============================================
# 公共变量定义
# ============================================

# PID 文件存储目录
PID_DIR := .pids
BACKEND_PID_FILE := $(PID_DIR)/backend.pid
FRONTEND_PID_FILE := $(PID_DIR)/frontend.pid
DOCS_PID_FILE := $(PID_DIR)/docs.pid

# 日志目录
LOG_DIR := ./dev-script/applogs
BACKEND_LOG := $(LOG_DIR)/backend.log
FRONTEND_LOG := $(LOG_DIR)/frontend.log
DOCS_LOG := $(LOG_DIR)/docs.log

# 创建必要目录
$(PID_DIR):
	@mkdir -p $(PID_DIR)

$(LOG_DIR):
	@mkdir -p $(LOG_DIR)

# 默认目标：显示帮助
.DEFAULT_GOAL := help

# ========== 目录配置 ==========
PID_DIR := .pids
LOG_DIR := .logs
BACKEND_PID_FILE := $(PID_DIR)/backend.pid
FRONTEND_PID_FILE := $(PID_DIR)/frontend.pid
DOCS_PID_FILE := $(PID_DIR)/docs.pid
BACKEND_LOG := $(LOG_DIR)/backend.log
FRONTEND_LOG := $(LOG_DIR)/frontend.log
DOCS_LOG := $(LOG_DIR)/docs.log

# 颜色输出
RED := \033[0;31m
GREEN := \033[0;32m
YELLOW := \033[1;33m
BLUE := \033[0;34m
NC := \033[0m # No Color