# ============================================
# 开发服务管理（前台 + 后台）
# ============================================

.PHONY: frontend backend docs dev
.PHONY: start start-backend start-frontend start-docs
.PHONY: stop stop-backend stop-frontend stop-docs
.PHONY: restart restart-backend restart-frontend restart-docs
.PHONY: status logs logs-backend logs-frontend logs-docs


# LOG_DIR = .logs
# PID_DIR = .pids

# $(LOG_DIR):
# 	mkdir -p $@

# $(PID_DIR):
# 	mkdir -p $@



# @启动前端（前台运行）
frontend: check-pnpm
	@echo "${GREEN}🚀 启动前端开发服务器（前台运行）...${NC}"
	@echo "📍 访问地址: http://localhost:3000"
	@echo "⚠️  按 Ctrl+C 停止服务"
	@cd frontend && pnpm run dev

# @启动前后（前台运行）
backend: check-go
	@echo "${GREEN}🚀 启动后端开发服务器（前台运行）...${NC}"
	@echo "📍 API 地址: http://localhost:8080"
	@echo "⚠️  按 Ctrl+C 停止服务"
	@cd backend && go run ./cmd/server/main.go

# @启动文档（前台运行）
docs: check-docsify
	@echo "${GREEN}📚 启动文档服务器（前台运行）...${NC}"
	@echo "📍 文档地址: http://localhost:3001"
	@echo "⚠️  按 Ctrl+C 停止服务"
	@cd docs && docsify serve

# @启动整个项目（后台运行：开发模式）
dev: check-deps
	@echo "${GREEN}🚀 同时启动前后端服务（前台运行）...${NC}"
	@./frontend/node_modules/.bin/concurrently --names "BACKEND,FRONTEND" --prefix-colors "cyan,yellow" "make frontend" "make backend"

# @启动项目（后台运行）
start: check-deps | $(PID_DIR) $(LOG_DIR) start-backend start-frontend start-docs
	@echo "${GREEN}✅ 所有服务已启动${NC}"
	@$(MAKE) status

# @启动后端（后台运行）
start-backend: check-go | $(PID_DIR) $(LOG_DIR)
	@if [ -f $(BACKEND_PID_FILE) ] && kill -0 $$(cat $(BACKEND_PID_FILE)) 2>/dev/null; then \
		echo "${YELLOW}⚠️  后端服务已在运行中 (PID: $$(cat $(BACKEND_PID_FILE)))${NC}"; \
	else \
		echo "${GREEN}🚀 正在启动后端服务（后台运行）...${NC}"; \
		cd backend && nohup go run ./cmd/server/main.go > ../$(BACKEND_LOG) 2>&1 & \
		echo $$! > $(BACKEND_PID_FILE); \
		sleep 2; \
		if kill -0 $$(cat $(BACKEND_PID_FILE)) 2>/dev/null; then \
			echo "${GREEN}✅ 后端服务启动成功 (PID: $$(cat $(BACKEND_PID_FILE)))${NC}"; \
			echo "📝 日志文件: $(BACKEND_LOG)"; \
			echo "📍 API 地址: http://localhost:8080"; \
		else \
			echo "${RED}❌ 后端服务启动失败，请检查日志: $(BACKEND_LOG)${NC}"; \
			rm -f $(BACKEND_PID_FILE); \
			exit 1; \
		fi \
	fi


# @启动前端（后台运行）
start-frontend: check-pnpm | $(PID_DIR) $(LOG_DIR)
	@if [ -f $(FRONTEND_PID_FILE) ] && kill -0 $$(cat $(FRONTEND_PID_FILE)) 2>/dev/null; then \
		echo "${YELLOW}⚠️  前端服务已在运行中 (PID: $$(cat $(FRONTEND_PID_FILE)))${NC}"; \
	else \
		echo "${GREEN}🚀 正在启动前端服务（后台运行）...${NC}"; \
		cd frontend && nohup pnpm run dev > ../$(FRONTEND_LOG) 2>&1 & \
		echo $$! > $(FRONTEND_PID_FILE); \
		sleep 3; \
		if kill -0 $$(cat $(FRONTEND_PID_FILE)) 2>/dev/null; then \
			echo "${GREEN}✅ 前端服务启动成功 (PID: $$(cat $(FRONTEND_PID_FILE)))${NC}"; \
			echo "📝 日志文件: $(FRONTEND_LOG)"; \
			echo "📍 访问地址: http://localhost:3000"; \
		else \
			echo "${RED}❌ 前端服务启动失败，请检查日志: $(FRONTEND_LOG)${NC}"; \
			rm -f $(FRONTEND_PID_FILE); \
			exit 1; \
		fi \
	fi

# @启动文档（后台运行）
start-docs: check-docsify | $(PID_DIR) $(LOG_DIR)
	@if [ -f $(DOCS_PID_FILE) ] && kill -0 $$(cat $(DOCS_PID_FILE)) 2>/dev/null; then \
		echo "${YELLOW}⚠️  文档服务已在运行中 (PID: $$(cat $(DOCS_PID_FILE)))${NC}"; \
	else \
		echo "${GREEN}📚 正在启动文档服务（后台运行）...${NC}"; \
		cd docs && nohup docsify serve > ../$(DOCS_LOG) 2>&1 & \
		echo $$! > $(DOCS_PID_FILE); \
		sleep 1; \
		if kill -0 $$(cat $(DOCS_PID_FILE)) 2>/dev/null; then \
			echo "${GREEN}✅ 文档服务启动成功 (PID: $$(cat $(DOCS_PID_FILE)))${NC}"; \
			echo "📝 日志文件: $(DOCS_LOG)"; \
			echo "📍 文档地址: http://localhost:3001"; \
		else \
			echo "${RED}❌ 文档服务启动失败，请检查日志: $(DOCS_LOG)${NC}"; \
			rm -f $(DOCS_PID_FILE); \
			exit 1; \
		fi \
	fi

# @停止服务
stop: stop-backend stop-frontend stop-docs
	@echo "${GREEN}✅ 所有服务已停止${NC}"

# @停止后端服务
stop-backend:
	@if [ -f $(BACKEND_PID_FILE) ]; then \
		PID=$$(cat $(BACKEND_PID_FILE)); \
		if kill -0 $$PID 2>/dev/null; then \
			echo "${YELLOW}🛑 正在停止后端服务 (PID: $$PID)...${NC}"; \
			kill -TERM $$PID; \
			sleep 2; \
			if kill -0 $$PID 2>/dev/null; then \
				echo "${YELLOW}⚠️  进程未响应，强制终止...${NC}"; \
				kill -KILL $$PID; \
			fi; \
			echo "${GREEN}✅ 后端服务已停止${NC}"; \
		else \
			echo "${YELLOW}⚠️  后端服务未运行（PID 文件过期）${NC}"; \
		fi; \
		rm -f $(BACKEND_PID_FILE); \
	else \
		echo "${YELLOW}⚠️  未找到后端 PID 文件（服务未运行）${NC}"; \
	fi

# @停止前端服务
stop-frontend:
	@if [ -f $(FRONTEND_PID_FILE) ]; then \
		PID=$$(cat $(FRONTEND_PID_FILE)); \
		if kill -0 $$PID 2>/dev/null; then \
			echo "${YELLOW}🛑 正在停止前端服务 (PID: $$PID)...${NC}"; \
			kill -TERM $$PID; \
			sleep 2; \
			if kill -0 $$PID 2>/dev/null; then \
				echo "${YELLOW}⚠️  进程未响应，强制终止...${NC}"; \
				kill -KILL $$PID; \
			fi; \
			echo "${GREEN}✅ 前端服务已停止${NC}"; \
		else \
			echo "${YELLOW}⚠️  前端服务未运行（PID 文件过期）${NC}"; \
		fi; \
		rm -f $(FRONTEND_PID_FILE); \
	else \
		echo "${YELLOW}⚠️  未找到前端 PID 文件（服务未运行）${NC}"; \
	fi

# @停止文档服务
stop-docs:
	@if [ -f $(DOCS_PID_FILE) ]; then \
		PID=$$(cat $(DOCS_PID_FILE)); \
		if kill -0 $$PID 2>/dev/null; then \
			echo "${YELLOW}🛑 正在停止文档服务 (PID: $$PID)...${NC}"; \
			kill -TERM $$PID; \
			sleep 1; \
			if kill -0 $$PID 2>/dev/null; then \
				echo "${YELLOW}⚠️  进程未响应，强制终止...${NC}"; \
				kill -KILL $$PID; \
			fi; \
			echo "${GREEN}✅ 文档服务已停止${NC}"; \
		else \
			echo "${YELLOW}⚠️  文档服务未运行（PID 文件过期）${NC}"; \
		fi; \
		rm -f $(DOCS_PID_FILE); \
	else \
		echo "${YELLOW}⚠️  未找到文档 PID 文件（服务未运行）${NC}"; \
	fi

# @重启
restart: stop start
	@echo "${GREEN}🔄 所有服务已重启${NC}"

# @重启后端
restart-backend: stop-backend start-backend
	@echo "${GREEN}🔄 后端服务已重启${NC}"

# @重启前端
restart-frontend: stop-frontend start-frontend
	@echo "${GREEN}🔄 前端服务已重启${NC}"

# @重启文档
restart-docs: stop-docs start-docs
	@echo "${GREEN}🔄 文档服务已重启${NC}"

# @状态检查
status:
	@echo "═══════════════════════════════════════════════════════════════"
	@echo "📊 服务运行状态"
	@echo "═══════════════════════════════════════════════════════════════"
	@echo ""
	@# Backend status
	@if [ -f $(BACKEND_PID_FILE) ]; then \
		PID=$$(cat $(BACKEND_PID_FILE)); \
		if kill -0 $$PID 2>/dev/null; then \
			echo "${GREEN}✅ 后端服务:     运行中 (PID: $$PID)${NC}"; \
			ps -p $$PID -o pid,vsz,rss,pcpu,comm --no-headers 2>/dev/null || true; \
		else \
			echo "${RED}❌ 后端服务:     已停止（PID 文件过期）${NC}"; \
			rm -f $(BACKEND_PID_FILE); \
		fi \
	else \
		echo "${RED}❌ 后端服务:     未运行${NC}"; \
	fi
	@echo ""
	@# Frontend status
	@if [ -f $(FRONTEND_PID_FILE) ]; then \
		PID=$$(cat $(FRONTEND_PID_FILE)); \
		if kill -0 $$PID 2>/dev/null; then \
			echo "${GREEN}✅ 前端服务:     运行中 (PID: $$PID)${NC}"; \
			ps -p $$PID -o pid,vsz,rss,pcpu,comm --no-headers 2>/dev/null || true; \
		else \
			echo "${RED}❌ 前端服务:     已停止（PID 文件过期）${NC}"; \
			rm -f $(FRONTEND_PID_FILE); \
		fi \
	else \
		echo "${RED}❌ 前端服务:     未运行${NC}"; \
	fi
	@echo ""
	@# Docs status
	@if [ -f $(DOCS_PID_FILE) ]; then \
		PID=$$(cat $(DOCS_PID_FILE)); \
		if kill -0 $$PID 2>/dev/null; then \
			echo "${GREEN}✅ 文档服务:     运行中 (PID: $$PID)${NC}"; \
			ps -p $$PID -o pid,vsz,rss,pcpu,comm --no-headers 2>/dev/null || true; \
		else \
			echo "${RED}❌ 文档服务:     已停止（PID 文件过期）${NC}"; \
			rm -f $(DOCS_PID_FILE); \
		fi \
	else \
		echo "${RED}❌ 文档服务:     未运行${NC}"; \
	fi
	@echo ""
	@echo "═══════════════════════════════════════════════════════════════"
	@echo "📁 PID 目录:      $(PID_DIR)"
	@echo "📝 日志目录:      $(LOG_DIR)"
	@echo "═══════════════════════════════════════════════════════════════"
	@echo ""
	@echo "📍 快速查看日志: make logs"
	@echo "📍 停止所有服务: make stop"

# @查看实时日志
logs:
	@echo "${BLUE}📝 实时查看所有日志（按 Ctrl+C 退出）...${NC}"
	@tail -f $(BACKEND_LOG) $(FRONTEND_LOG) $(DOCS_LOG) 2>/dev/null || echo "${YELLOW}未找到日志文件，请先运行 'make start' 启动服务${NC}"

# @查看后端实时日志
logs-backend:
	@echo "${BLUE}📝 实时查看后端日志（按 Ctrl+C 退出）...${NC}"
	@tail -f $(BACKEND_LOG) 2>/dev/null || echo "${YELLOW}未找到后端日志文件，请先运行 'make start-backend'${NC}"

# @查看前端实时日志
logs-frontend:
	@echo "${BLUE}📝 实时查看前端日志（按 Ctrl+C 退出）...${NC}"
	@tail -f $(FRONTEND_LOG) 2>/dev/null || echo "${YELLOW}未找到前端日志文件，请先运行 'make start-frontend'${NC}"

# @查看文档实时日志
logs-docs:
	@echo "${BLUE}📝 实时查看文档日志（按 Ctrl+C 退出）...${NC}"
	@tail -f $(DOCS_LOG) 2>/dev/null || echo "${YELLOW}未找到文档日志文件，请先运行 'make start-docs'${NC}"

# @快捷启动项目
up: start
	@echo ""
	@echo "${GREEN}═══════════════════════════════════════════════════════════════${NC}"
	@echo "${GREEN}🎉 服务已启动！${NC}"
	@echo "${GREEN}═══════════════════════════════════════════════════════════════${NC}"
	@echo "  🌐 前端: ${BLUE}http://localhost:3000${NC}"
	@echo "  ⚙️  后端: ${BLUE}http://localhost:8080${NC}"
	@echo "  📚 文档: ${BLUE}http://localhost:3001${NC}"
	@echo ""
	@echo "  📝 查看日志: ${YELLOW}make logs${NC}"
	@echo "  🛑 停止服务: ${YELLOW}make stop${NC}"
	@echo "${GREEN}═══════════════════════════════════════════════════════════════${NC}"
# @快捷停止项目
down: stop

# @开发环境初始化
init: check-deps
	@echo "${GREEN}🚀 初始化开发环境...${NC}"
	@echo "${BLUE}📦 安装前端依赖...${NC}"
	@cd frontend && pnpm install
	@echo "${BLUE}📦 下载后端依赖...${NC}"
	@cd backend && go mod download
	@echo "${GREEN}✅ 开发环境初始化完成${NC}"
	@echo ""
	@echo "💡 现在可以运行: make up"


# 帮助信息
.PHONY: dev-help
# @此帮助信息
dev-help:
	@$(MAKE) -s _print_help SELF_MAKEFILE_PATH='$(MAKEFILE_DEV_PATH)'
	@echo ""
