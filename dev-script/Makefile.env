# =============================================================
# Makefile.env
# 自动读取 .env 和 backend/config/*.yaml，统一注入环境变量
# 用法：在主 Makefile 中 include dev-script/Makefile.env
# =============================================================

# ── 路径约定 ─────────────────────────────────────────────────
ROOT_DIR        := $(dir $(abspath $(lastword $(MAKEFILE_LIST))))..
ENV_FILE        := $(ROOT_DIR)/.env
BACKEND_CFG_DIR := $(ROOT_DIR)/backend/config

BASIC_YAML_REAL   := $(BACKEND_CFG_DIR)/basic.yaml
PRIVATE_YAML_REAL := $(BACKEND_CFG_DIR)/private.yaml

# example 回退：正式文件不存在时读示例
BASIC_YAML_SRC   := $(or $(wildcard $(BASIC_YAML_REAL)),$(BACKEND_CFG_DIR)/basic.example.yaml)
PRIVATE_YAML_SRC := $(or $(wildcard $(PRIVATE_YAML_REAL)),$(BACKEND_CFG_DIR)/private.example.yaml)

# ── 工具检测（用 which，兼容 /bin/sh）────────────────────────
_YQ      := $(shell which yq      2>/dev/null)
_PYTHON3 := $(shell which python3 2>/dev/null)

# ── Python 解析脚本（写到临时文件，避免括号嵌套语法错误）────
_YAML_PY := /tmp/_makefile_yaml_get.py
$(shell printf '%s\n' \
  'import sys, yaml, functools' \
  'path, key = sys.argv[1], sys.argv[2]' \
  'd = yaml.safe_load(open(path))' \
  'v = functools.reduce(lambda a,k: a.get(k,{}) if isinstance(a,dict) else "", key.split("."), d)' \
  'print("" if isinstance(v,(dict,type(None))) else v)' \
  > $(_YAML_PY))

# yaml_val(file, dotted.key) → 裸值字符串
ifneq ($(_YQ),)
  yaml_val = $(shell $(_YQ) -r '.$(2) // ""' '$(1)' 2>/dev/null)
else ifneq ($(_PYTHON3),)
  yaml_val = $(shell $(_PYTHON3) $(_YAML_PY) '$(1)' '$(2)' 2>/dev/null)
else
  $(warning [Makefile.env] 警告：未找到 yq 或 python3，YAML 将不被解析)
  yaml_val =
endif

# ── 从 .env 加载 ─────────────────────────────────────────────
ifneq ("$(wildcard $(ENV_FILE))","")
  include $(ENV_FILE)
  export $(shell sed \
    -e '/^[[:space:]]*\#/d' \
    -e '/^[[:space:]]*$$/d' \
    -e 's/[[:space:]]*\#[^"]*$$//' \
    $(ENV_FILE) | grep '=' | cut -d= -f1)
endif

# ── 从 basic.yaml 读取 ───────────────────────────────────────
ifneq ("$(wildcard $(BASIC_YAML_SRC))","")
  YAML_SERVER_PORT  := $(call yaml_val,$(BASIC_YAML_SRC),server.port)
  YAML_SERVER_MODE  := $(call yaml_val,$(BASIC_YAML_SRC),server.mode)
  YAML_LOG_LEVEL    := $(call yaml_val,$(BASIC_YAML_SRC),log.level)
  YAML_CDN_DOMAIN   := $(call yaml_val,$(BASIC_YAML_SRC),upload.cdn_domain)
  YAML_UPLOAD_PATH  := $(call yaml_val,$(BASIC_YAML_SRC),upload.storage_path)
  YAML_OLLAMA_URL   := $(call yaml_val,$(BASIC_YAML_SRC),ollama.base_url)
  YAML_OLLAMA_MODEL := $(call yaml_val,$(BASIC_YAML_SRC),ollama.model)
  YAML_JWT_SECRET_B := $(call yaml_val,$(BASIC_YAML_SRC),jwt.secret)
  YAML_JWT_EXPIRE_B := $(call yaml_val,$(BASIC_YAML_SRC),jwt.expire)
endif

# ── 从 private.yaml 读取 ─────────────────────────────────────
ifneq ("$(wildcard $(PRIVATE_YAML_SRC))","")
  YAML_DB_HOST        := $(call yaml_val,$(PRIVATE_YAML_SRC),database.host)
  YAML_DB_PORT        := $(call yaml_val,$(PRIVATE_YAML_SRC),database.port)
  YAML_DB_USER        := $(call yaml_val,$(PRIVATE_YAML_SRC),database.user)
  YAML_DB_PASSWORD    := $(call yaml_val,$(PRIVATE_YAML_SRC),database.password)
  YAML_DB_NAME        := $(call yaml_val,$(PRIVATE_YAML_SRC),database.dbname)
  YAML_DB_SSLMODE     := $(call yaml_val,$(PRIVATE_YAML_SRC),database.sslmode)
  YAML_REDIS_HOST     := $(call yaml_val,$(PRIVATE_YAML_SRC),redis.host)
  YAML_REDIS_PORT     := $(call yaml_val,$(PRIVATE_YAML_SRC),redis.port)
  YAML_REDIS_PASSWORD := $(call yaml_val,$(PRIVATE_YAML_SRC),redis.password)
  YAML_EMAIL_HOST     := $(call yaml_val,$(PRIVATE_YAML_SRC),email.host)
  YAML_EMAIL_PORT     := $(call yaml_val,$(PRIVATE_YAML_SRC),email.port)
  YAML_EMAIL_USER     := $(call yaml_val,$(PRIVATE_YAML_SRC),email.username)
  YAML_EMAIL_PASS     := $(call yaml_val,$(PRIVATE_YAML_SRC),email.password)
  YAML_EMAIL_FROM     := $(call yaml_val,$(PRIVATE_YAML_SRC),email.from)
  YAML_JWT_SECRET     := $(call yaml_val,$(PRIVATE_YAML_SRC),jwt.secret)
  YAML_JWT_EXPIRE     := $(call yaml_val,$(PRIVATE_YAML_SRC),jwt.expire)
  YAML_ADMIN_EMAIL    := $(call yaml_val,$(PRIVATE_YAML_SRC),admin.email)
  YAML_ADMIN_PASS     := $(call yaml_val,$(PRIVATE_YAML_SRC),admin.password)
  YAML_ADMIN_USER     := $(call yaml_val,$(PRIVATE_YAML_SRC),admin.username)
endif

# ── 合并：.env 优先，yaml 次之，内置默认值兜底 ───────────────
BACKEND_PORT   ?= $(or $(YAML_SERVER_PORT),8080)
SERVER_MODE    ?= $(or $(YAML_SERVER_MODE),debug)
LOG_LEVEL      ?= $(or $(YAML_LOG_LEVEL),info)
CDN_DOMAIN     ?= $(YAML_CDN_DOMAIN)
UPLOAD_PATH    ?= $(or $(YAML_UPLOAD_PATH),./uploads)

DB_HOST        ?= $(or $(YAML_DB_HOST),localhost)
DB_PORT        ?= $(or $(YAML_DB_PORT),5432)
DB_USER        ?= $(or $(YAML_DB_USER),postgres)
DB_PASSWORD    ?= $(or $(YAML_DB_PASSWORD),postgres)
DB_NAME        ?= $(or $(YAML_DB_NAME),tiny_forum)
DB_SSLMODE     ?= $(or $(YAML_DB_SSLMODE),disable)

REDIS_HOST     ?= $(or $(YAML_REDIS_HOST),localhost)
REDIS_PORT     ?= $(or $(YAML_REDIS_PORT),6379)
REDIS_PASSWORD ?= $(YAML_REDIS_PASSWORD)

# JWT：private.yaml 优先于 basic.yaml
JWT_SECRET     ?= $(or $(YAML_JWT_SECRET),$(YAML_JWT_SECRET_B),change-me-in-production)
JWT_EXPIRE     ?= $(or $(YAML_JWT_EXPIRE),$(YAML_JWT_EXPIRE_B),24h)

EMAIL_HOST     ?= $(YAML_EMAIL_HOST)
EMAIL_PORT     ?= $(or $(YAML_EMAIL_PORT),587)
EMAIL_USERNAME ?= $(YAML_EMAIL_USER)
EMAIL_PASSWORD ?= $(YAML_EMAIL_PASS)
EMAIL_FROM     ?= $(YAML_EMAIL_FROM)

ADMIN_EMAIL    ?= $(YAML_ADMIN_EMAIL)
ADMIN_PASSWORD ?= $(YAML_ADMIN_PASS)
ADMIN_USERNAME ?= $(YAML_ADMIN_USER)

OLLAMA_BASE_URL ?= $(or $(YAML_OLLAMA_URL),http://localhost:11434)
OLLAMA_MODEL    ?= $(or $(YAML_OLLAMA_MODEL),qwen3:0.6b)

# nginx 端口只来自 .env
HTTP_PORT      ?= 8080
HTTPS_PORT     ?= 8443

# ── 统一 export ───────────────────────────────────────────────
export BACKEND_PORT SERVER_MODE LOG_LEVEL CDN_DOMAIN UPLOAD_PATH
export DB_HOST DB_PORT DB_USER DB_PASSWORD DB_NAME DB_SSLMODE
export REDIS_HOST REDIS_PORT REDIS_PASSWORD
export JWT_SECRET JWT_EXPIRE
export EMAIL_HOST EMAIL_PORT EMAIL_USERNAME EMAIL_PASSWORD EMAIL_FROM
export ADMIN_EMAIL ADMIN_PASSWORD ADMIN_USERNAME
export OLLAMA_BASE_URL OLLAMA_MODEL
export HTTP_PORT HTTPS_PORT

# ── 辅助目标 ─────────────────────────────────────────────────
.PHONY: env-show env-check env-gen-dotenv

## 打印所有合并后变量
env-show:
	@echo "=== Makefile.env — 合并后环境变量 ==="
	@echo "  [工具]"
	@echo "    yq      = $(_YQ)"
	@echo "    python3 = $(_PYTHON3)"
	@echo "  [服务器]"
	@echo "    BACKEND_PORT    = $(BACKEND_PORT)"
	@echo "    SERVER_MODE     = $(SERVER_MODE)"
	@echo "    LOG_LEVEL       = $(LOG_LEVEL)"
	@echo "    HTTP_PORT       = $(HTTP_PORT)"
	@echo "    HTTPS_PORT      = $(HTTPS_PORT)"
	@echo "  [数据库]"
	@echo "    DB_HOST         = $(DB_HOST)"
	@echo "    DB_PORT         = $(DB_PORT)"
	@echo "    DB_USER         = $(DB_USER)"
	@echo "    DB_PASSWORD     = $(DB_PASSWORD)"
	@echo "    DB_NAME         = $(DB_NAME)"
	@echo "    DB_SSLMODE      = $(DB_SSLMODE)"
	@echo "  [Redis]"
	@echo "    REDIS_HOST      = $(REDIS_HOST)"
	@echo "    REDIS_PORT      = $(REDIS_PORT)"
	@echo "    REDIS_PASSWORD  = $(REDIS_PASSWORD)"
	@echo "  [JWT]"
	@echo "    JWT_SECRET      = $(JWT_SECRET)"
	@echo "    JWT_EXPIRE      = $(JWT_EXPIRE)"
	@echo "  [邮件]"
	@echo "    EMAIL_HOST      = $(EMAIL_HOST)"
	@echo "    EMAIL_PORT      = $(EMAIL_PORT)"
	@echo "    EMAIL_USERNAME  = $(EMAIL_USERNAME)"
	@echo "    EMAIL_FROM      = $(EMAIL_FROM)"
	@echo "  [Ollama]"
	@echo "    OLLAMA_BASE_URL = $(OLLAMA_BASE_URL)"
	@echo "    OLLAMA_MODEL    = $(OLLAMA_MODEL)"
	@echo "  [管理员]"
	@echo "    ADMIN_EMAIL     = $(ADMIN_EMAIL)"
	@echo "    ADMIN_USERNAME  = $(ADMIN_USERNAME)"
	@echo "  [上传/CDN]"
	@echo "    UPLOAD_PATH     = $(UPLOAD_PATH)"
	@echo "    CDN_DOMAIN      = $(CDN_DOMAIN)"
	@echo "======================================"

## 检查必填变量
env-check:
	@missing=""; \
	for v in BACKEND_PORT DB_USER DB_PASSWORD DB_NAME JWT_SECRET; do \
	  val=$$(printenv $$v); \
	  if [ -z "$$val" ]; then missing="$$missing $$v"; fi; \
	done; \
	if [ -n "$$missing" ]; then \
	  echo "[Makefile.env] ❌ 缺少必填变量:$$missing"; exit 1; \
	else \
	  echo "[Makefile.env] ✅ 必填变量检查通过"; \
	fi

## 根据当前合并值生成 .env（文件已存在则跳过）
env-gen-dotenv:
	@if [ -f "$(ENV_FILE)" ]; then \
	  echo "[Makefile.env] .env 已存在，跳过（手动删除后重新运行）"; \
	else \
	  { \
	    echo "# 由 make env-gen-dotenv 自动生成，请按需修改"; \
	    echo "BACKEND_PORT=$(BACKEND_PORT)"; \
	    echo "SERVER_MODE=$(SERVER_MODE)"; \
	    echo "LOG_LEVEL=$(LOG_LEVEL)"; \
	    echo "HTTP_PORT=$(HTTP_PORT)"; \
	    echo "HTTPS_PORT=$(HTTPS_PORT)"; \
	    echo "DB_HOST=$(DB_HOST)"; \
	    echo "DB_PORT=$(DB_PORT)"; \
	    echo "DB_USER=$(DB_USER)"; \
	    echo "DB_PASSWORD=$(DB_PASSWORD)"; \
	    echo "DB_NAME=$(DB_NAME)"; \
	    echo "DB_SSLMODE=$(DB_SSLMODE)"; \
	    echo "REDIS_HOST=$(REDIS_HOST)"; \
	    echo "REDIS_PORT=$(REDIS_PORT)"; \
	    echo "REDIS_PASSWORD=$(REDIS_PASSWORD)"; \
	    echo "JWT_SECRET=$(JWT_SECRET)"; \
	    echo "JWT_EXPIRE=$(JWT_EXPIRE)"; \
	    echo "EMAIL_HOST=$(EMAIL_HOST)"; \
	    echo "EMAIL_PORT=$(EMAIL_PORT)"; \
	    echo "EMAIL_USERNAME=$(EMAIL_USERNAME)"; \
	    echo "EMAIL_PASSWORD=$(EMAIL_PASSWORD)"; \
	    echo "EMAIL_FROM=$(EMAIL_FROM)"; \
	    echo "CDN_DOMAIN=$(CDN_DOMAIN)"; \
	    echo "UPLOAD_PATH=$(UPLOAD_PATH)"; \
	    echo "ADMIN_EMAIL=$(ADMIN_EMAIL)"; \
	    echo "ADMIN_PASSWORD=$(ADMIN_PASSWORD)"; \
	    echo "ADMIN_USERNAME=$(ADMIN_USERNAME)"; \
	    echo "OLLAMA_BASE_URL=$(OLLAMA_BASE_URL)"; \
	    echo "OLLAMA_MODEL=$(OLLAMA_MODEL)"; \
	  } > $(ENV_FILE); \
	  echo "[Makefile.env] ✅ 已生成 $(ENV_FILE)"; \
	fi
env-help:
	@echo "=== Makefile.env — 帮助 ==="
	@echo "  make env-show       # 打印所有合并后变量"
	@echo "  make env-check      # 检查必填变量"
	@echo "  make env-gen-dotenv # 根据当前合并值生成 .env（文件已存在则跳过）"
    