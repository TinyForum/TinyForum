# ==============================================================================
# Makefile.env  —  .env 环境变量管理
#
# 所有实际逻辑委托给 scripts/env.sh（模块化 Bash 脚本）。
# 本文件只负责：加载 .env 变量到 Make 进程 + 暴露 make 目标。
# ==============================================================================

# ── 路径 ──────────────────────────────────────────────────────────────────────
_ENV_ROOT     := $(abspath $(dir $(abspath $(lastword $(MAKEFILE_LIST)))))
ENV_FILE      ?= $(_ENV_ROOT)/.env
ENV_EXAMPLE   ?= $(_ENV_ROOT)/.env.example
ENV_SCRIPT    ?= $(_ENV_ROOT)/scripts/env.sh
CONFIG_DIR    ?= $(_ENV_ROOT)/config

# ── 加载 .env（Make 进程级别）────────────────────────────────────────────────
ifneq ("$(wildcard $(ENV_FILE))","")
  include $(ENV_FILE)
  export $(shell grep -E '^[A-Za-z_][A-Za-z0-9_]*=' $(ENV_FILE) | cut -d= -f1)
endif

# ── Schema 默认值（仅当变量完全未定义时生效）─────────────────────────────────
SERVER_HOST        ?= localhost
SERVER_PORT        ?= 8080
SERVER_MODE        ?= debug
FRONTEND_PORT      ?= 3000
DB_HOST            ?= localhost
DB_PORT            ?= 5432
DB_USER            ?= postgres
DB_PASSWORD        ?= postgres
DB_NAME            ?= tiny_forum
DB_SSLMODE         ?= disable
REDIS_HOST         ?= localhost
REDIS_PORT         ?= 6379
REDIS_PASSWORD     ?=
JWT_SECRET         ?= tiny-forum-secret-change-in-production-32chars
JWT_EXPIRE         ?= 24h
LOG_LEVEL          ?= info
UPLOAD_DIR         ?= ./uploads
OLLAMA_BASE_URL    ?= http://localhost:11434
OLLAMA_MODEL       ?= qwen3:0.6b

export SERVER_HOST SERVER_PORT SERVER_MODE FRONTEND_PORT
export DB_HOST DB_PORT DB_USER DB_PASSWORD DB_NAME DB_SSLMODE
export REDIS_HOST REDIS_PORT REDIS_PASSWORD
export JWT_SECRET JWT_EXPIRE LOG_LEVEL UPLOAD_DIR
export OLLAMA_BASE_URL OLLAMA_MODEL

# ── 工具宏（检查 env.sh 可执行）──────────────────────────────────────────────
define _env_check_script
	@if [ ! -x "$(ENV_SCRIPT)" ]; then \
	  printf "\033[31m[env] 脚本不存在或不可执行: $(ENV_SCRIPT)\033[0m\n"; exit 1; \
	fi
endef

define _run_env
	$(call _env_check_script)
	@$(ENV_SCRIPT) $(1) \
	  --env-file "$(ENV_FILE)" \
	  --example  "$(ENV_EXAMPLE)" \
	  --config-dir "$(CONFIG_DIR)" \
	  $(2) \
	   $(if $(FORCE),--force) \
	  $(if $(VERBOSE),--verbose)
endef

# ==============================================================================
# Make 目标
# ==============================================================================
.PHONY: env-help env-init env-generate env-sync env-edit env-show \
        env-check env-validate env-list-keys env-diff env-export \
        env-get env-set env-unset env-gen-example

# @初始化 .env（从 YAML 文件自动生成，存在时报错，使用 FORCE=1 覆盖）
env-init:
	$(call _run_env, init)
# @强制覆盖环境变量
env-init-force:
	$(call _run_env,init,--force)
# @生成带注释的 .env
env-generate:
	$(call _run_env, generate --annotated)

# @从 YAML 增量同步 .env（保留敏感字段手动值）
env-sync:
	$(call _run_env, sync-yaml)

# @用系统编辑器编辑 .env
env-edit:
	$(call _run_env, edit)

# @显示当前 .env（敏感字段脱敏）
env-show:
	$(call _run_env, show)

## 必填项快速检查
env-check:
	$(call _run_env, check)

# @全量 schema 校验 + 格式报告
env-validate:
	$(call _run_env, validate)

# @列出所有 schema 键、默认值、说明
env-list-keys:
	$(call _run_env, list-keys)

# @对比 .env 与 .env.example
env-diff:
	$(call _run_env, diff)

# @输出 export 语句（供 eval 使用）
env-export:
	$(call _run_env, export)

# @获取单个键: make env-get KEY=DB_PASSWORD
env-get:
	@if [ -z "$(KEY)" ]; then \
	  printf "\033[31m用法: make env-get KEY=变量名\033[0m\n"; exit 1; \
	fi
	$(call _run_env, get --key "$(KEY)")

# @设置单个键: make env-set KEY=DB_PASSWORD VALUE=secret
env-set:
	@if [ -z "$(KEY)" ] || [ -z "$(VALUE)" ]; then \
	  printf "\033[31m用法: make env-set KEY=变量名 VALUE=值\033[0m\n"; exit 1; \
	fi
	$(call _run_env, set --key "$(KEY)" --value "$(VALUE)")

# @删除单个键: make env-unset KEY=OLD_VAR
env-unset:
	@if [ -z "$(KEY)" ]; then \
	  printf "\033[31m用法: make env-unset KEY=变量名\033[0m\n"; exit 1; \
	fi
	$(call _run_env, unset --key "$(KEY)")

# @重新生成 .env.example（敏感字段留空）
env-gen-example:
	$(call _run_env, gen-example)

## 显示 env 管理命令帮助
# env-help:
# 	$(call _env_check_script)
# 	@$(ENV_SCRIPT) help
.PHONY: env-help
# @此帮助信息
env-help:
# 	@echo "${RED} 暂不建议使用，将来计划移除"
	@$(MAKE) -s _print_help SELF_MAKEFILE_PATH='$(MAKEFILE_ENV_PATH)'
