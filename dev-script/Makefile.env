# ==============================================================================
# Makefile.env  —  .env 环境变量管理
#
# 职责：仅负责 .env 文件的读取、创建、检查、查看和变量操作。
#       YAML 配置文件由 Makefile.cfg 负责，两者相互独立。
#
# 用法：在父 Makefile 中加入：
#         include dev-script/Makefile.env
#
# 快速开始：
#   make env-help          查看所有 env 相关命令
#   make env-init          从模板生成 .env
#   make env-show          查看当前所有变量
#   make env-check         检查必填变量
#   make env-get KEY=xxx   读取单个变量
#   make env-set KEY=xxx VALUE=yyy  写入/修改单个变量
# ==============================================================================

# ── 路径 ──────────────────────────────────────────────────────────────────────
_ENV_SELF_DIR := $(dir $(abspath $(lastword $(MAKEFILE_LIST))))
_ENV_ROOT     := $(abspath $(_ENV_SELF_DIR)/..)

ENV_FILE      ?= $(_ENV_ROOT)/.env
ENV_EXAMPLE   ?= $(_ENV_ROOT)/.env.example

# ── 加载 .env（存在时）────────────────────────────────────────────────────────
# 用 ?= 展开，命令行传入的变量优先级更高
ifneq ("$(wildcard $(ENV_FILE))","")
  # 逐行读取：跳过注释和空行，剥离行内注释，再 include
  $(foreach _line,\
    $(shell sed \
      -e '/^[[:space:]]*\#/d' \
      -e '/^[[:space:]]*$$/d' \
      -e 's/[[:space:]]*\#[^"'\'']*$$//' \
      $(ENV_FILE) | grep -E '^[A-Za-z_][A-Za-z0-9_]*='),\
    $(eval $(_line))\
  )
  # 同时 export 所有 key
  export $(shell sed \
    -e '/^[[:space:]]*\#/d' \
    -e '/^[[:space:]]*$$/d' \
    $(ENV_FILE) | grep -E '^[A-Za-z_][A-Za-z0-9_]*=' | cut -d= -f1)
endif

# ── 内置默认值（仅当变量完全未定义时生效）────────────────────────────────────
BACKEND_PORT   ?= 8080
SERVER_MODE    ?= debug
LOG_LEVEL      ?= info
HTTP_PORT      ?= 8080
HTTPS_PORT     ?= 8443
DB_HOST        ?= localhost
DB_PORT        ?= 5432
DB_USER        ?= postgres
DB_PASSWORD    ?= postgres
DB_NAME        ?= tiny_forum
DB_SSLMODE     ?= disable
REDIS_HOST     ?= localhost
REDIS_PORT     ?= 6379
REDIS_PASSWORD ?=
JWT_SECRET     ?= change-me-in-production
JWT_EXPIRE     ?= 24h
EMAIL_HOST     ?=
EMAIL_PORT     ?= 587
EMAIL_USERNAME ?=
EMAIL_PASSWORD ?=
EMAIL_FROM     ?=
CDN_DOMAIN     ?=
UPLOAD_PATH    ?= ./uploads
ADMIN_EMAIL    ?=
ADMIN_PASSWORD ?=
ADMIN_USERNAME ?=
OLLAMA_BASE_URL ?= http://localhost:11434
OLLAMA_MODEL    ?= qwen3:0.6b

export BACKEND_PORT SERVER_MODE LOG_LEVEL HTTP_PORT HTTPS_PORT
export DB_HOST DB_PORT DB_USER DB_PASSWORD DB_NAME DB_SSLMODE
export REDIS_HOST REDIS_PORT REDIS_PASSWORD
export JWT_SECRET JWT_EXPIRE
export EMAIL_HOST EMAIL_PORT EMAIL_USERNAME EMAIL_PASSWORD EMAIL_FROM
export CDN_DOMAIN UPLOAD_PATH
export ADMIN_EMAIL ADMIN_PASSWORD ADMIN_USERNAME
export OLLAMA_BASE_URL OLLAMA_MODEL

# ── 必填变量列表（env-check 时校验）─────────────────────────────────────────
_ENV_REQUIRED := BACKEND_PORT DB_USER DB_PASSWORD DB_NAME JWT_SECRET

# ── 颜色（终端支持时启用）────────────────────────────────────────────────────
_C_RESET  := \033[0m
_C_BOLD   := \033[1m
_C_GREEN  := \033[32m
_C_YELLOW := \033[33m
_C_RED    := \033[31m
_C_CYAN   := \033[36m
_C_GRAY   := \033[90m

# ==============================================================================
# 目标
# ==============================================================================
.PHONY: env-help env-init env-edit env-show env-check \
        env-get env-set env-unset env-list-keys env-diff env-validate

# ── env-help ──────────────────────────────────────────────────────────────────
## 显示 env 模块帮助
env-help:
	@printf "$(_C_BOLD)$(_C_CYAN)Makefile.env — .env 环境变量管理$(_C_RESET)\n"
	@printf "\n"
	@printf "$(_C_BOLD)文件$(_C_RESET)\n"
	@printf "  ENV_FILE    $(ENV_FILE)\n"
	@printf "  ENV_EXAMPLE $(ENV_EXAMPLE)\n"
	@printf "\n"
	@printf "$(_C_BOLD)命令$(_C_RESET)\n"
	@printf "  $(_C_GREEN)make env-init$(_C_RESET)                    从 .env.example 生成 .env（已存在则跳过）\n"
	@printf "  $(_C_GREEN)make env-init FORCE=1$(_C_RESET)            强制覆盖已有 .env\n"
	@printf "  $(_C_GREEN)make env-edit$(_C_RESET)                    用 \$$EDITOR 打开 .env\n"
	@printf "  $(_C_GREEN)make env-show$(_C_RESET)                    打印当前所有已加载变量\n"
	@printf "  $(_C_GREEN)make env-check$(_C_RESET)                   检查必填变量是否已设置\n"
	@printf "  $(_C_GREEN)make env-validate$(_C_RESET)                校验变量格式（端口范围、非空等）\n"
	@printf "  $(_C_GREEN)make env-list-keys$(_C_RESET)               列出 .env 中所有 KEY 名称\n"
	@printf "  $(_C_GREEN)make env-get KEY=FOO$(_C_RESET)             读取单个变量的值\n"
	@printf "  $(_C_GREEN)make env-set KEY=FOO VALUE=bar$(_C_RESET)   写入或更新单个变量\n"
	@printf "  $(_C_GREEN)make env-unset KEY=FOO$(_C_RESET)           从 .env 中删除单个变量\n"
	@printf "  $(_C_GREEN)make env-diff$(_C_RESET)                    对比 .env 与 .env.example 的差异\n"
	@printf "\n"
	@printf "$(_C_BOLD)必填变量$(_C_RESET)\n"
	@printf "  $(_ENV_REQUIRED)\n"
	@printf "\n"
	@printf "$(_C_BOLD)优先级$(_C_RESET)（高 → 低）\n"
	@printf "  命令行参数  >  .env 文件  >  Makefile 内置默认值\n"

# ── env-init ──────────────────────────────────────────────────────────────────
## 从 .env.example 生成 .env
env-init:
	@if [ -f "$(ENV_FILE)" ] && [ "$(FORCE)" != "1" ]; then \
	  printf "$(_C_YELLOW)[env] .env 已存在，跳过。用 make env-init FORCE=1 强制覆盖$(_C_RESET)\n"; \
	elif [ ! -f "$(ENV_EXAMPLE)" ]; then \
	  printf "$(_C_YELLOW)[env] 未找到 $(ENV_EXAMPLE)，生成内置模板$(_C_RESET)\n"; \
	  $(MAKE) --no-print-directory _env-write-builtin-example; \
	  cp $(ENV_EXAMPLE) $(ENV_FILE); \
	  printf "$(_C_GREEN)[env] ✅ 已生成 $(ENV_FILE)$(_C_RESET)\n"; \
	else \
	  cp $(ENV_EXAMPLE) $(ENV_FILE); \
	  printf "$(_C_GREEN)[env] ✅ 已从 $(ENV_EXAMPLE) 生成 $(ENV_FILE)$(_C_RESET)\n"; \
	fi

# 写出内置 .env.example（当用户没有提供时的兜底）
.PHONY: _env-write-builtin-example
_env-write-builtin-example:
	@{ \
	  echo "# ============================================================"; \
	  echo "# .env.example  —  复制为 .env 并填写真实值"; \
	  echo "# ============================================================"; \
	  echo ""; \
	  echo "# ---------- 服务器 ----------"; \
	  echo "BACKEND_PORT=8080"; \
	  echo "SERVER_MODE=debug          # debug | release"; \
	  echo "LOG_LEVEL=info             # debug | info | warn | error"; \
	  echo "HTTP_PORT=8080"; \
	  echo "HTTPS_PORT=8443"; \
	  echo ""; \
	  echo "# ---------- 数据库 ----------"; \
	  echo "DB_HOST=localhost"; \
	  echo "DB_PORT=5432"; \
	  echo "DB_USER=postgres"; \
	  echo "DB_PASSWORD=postgres"; \
	  echo "DB_NAME=tiny_forum"; \
	  echo "DB_SSLMODE=disable"; \
	  echo ""; \
	  echo "# ---------- Redis ----------"; \
	  echo "REDIS_HOST=localhost"; \
	  echo "REDIS_PORT=6379"; \
	  echo "REDIS_PASSWORD="; \
	  echo ""; \
	  echo "# ---------- JWT ----------"; \
	  echo "JWT_SECRET=change-me-in-production-32chars"; \
	  echo "JWT_EXPIRE=24h"; \
	  echo ""; \
	  echo "# ---------- 邮件（可选）----------"; \
	  echo "EMAIL_HOST=smtp.gmail.com"; \
	  echo "EMAIL_PORT=587"; \
	  echo "EMAIL_USERNAME=noreply@example.com"; \
	  echo "EMAIL_PASSWORD=your-email-password"; \
	  echo "EMAIL_FROM=noreply@example.com"; \
	  echo ""; \
	  echo "# ---------- 上传 / CDN（可选）----------"; \
	  echo "UPLOAD_PATH=./uploads"; \
	  echo "CDN_DOMAIN=https://cdn.example.com"; \
	  echo ""; \
	  echo "# ---------- Nginx ----------"; \
	  echo "HTTP_PORT=8080"; \
	  echo "HTTPS_PORT=8443"; \
	  echo ""; \
	  echo "# ---------- Ollama（可选）----------"; \
	  echo "OLLAMA_BASE_URL=http://localhost:11434"; \
	  echo "OLLAMA_MODEL=qwen3:0.6b"; \
	  echo ""; \
	  echo "# ---------- 管理员初始账号（首次部署）----------"; \
	  echo "ADMIN_EMAIL=admin@example.com"; \
	  echo "ADMIN_PASSWORD=change-me"; \
	  echo "ADMIN_USERNAME=admin"; \
	} > $(ENV_EXAMPLE)

# ── env-edit ──────────────────────────────────────────────────────────────────
## 用 $EDITOR 打开 .env
env-edit:
	@if [ ! -f "$(ENV_FILE)" ]; then \
	  printf "$(_C_YELLOW)[env] .env 不存在，请先运行 make env-init$(_C_RESET)\n"; exit 1; \
	fi
	@$${EDITOR:-vi} $(ENV_FILE)

# ── env-show ──────────────────────────────────────────────────────────────────
## 打印当前所有已加载的环境变量
env-show:
	@printf "$(_C_BOLD)$(_C_CYAN)=== .env 当前变量值 ===$(_C_RESET)\n"
	@_loaded="$$([ -f '$(ENV_FILE)' ] && echo '$(ENV_FILE)' || echo '（未找到 .env，使用默认值）')"; \
	 printf "$(_C_GRAY)来源: $$_loaded$(_C_RESET)\n\n"
	@printf "$(_C_BOLD)[服务器]$(_C_RESET)\n"
	@printf "  %-20s = %s\n" "BACKEND_PORT"   "$(BACKEND_PORT)"
	@printf "  %-20s = %s\n" "SERVER_MODE"    "$(SERVER_MODE)"
	@printf "  %-20s = %s\n" "LOG_LEVEL"      "$(LOG_LEVEL)"
	@printf "  %-20s = %s\n" "HTTP_PORT"      "$(HTTP_PORT)"
	@printf "  %-20s = %s\n" "HTTPS_PORT"     "$(HTTPS_PORT)"
	@printf "$(_C_BOLD)[数据库]$(_C_RESET)\n"
	@printf "  %-20s = %s\n" "DB_HOST"        "$(DB_HOST)"
	@printf "  %-20s = %s\n" "DB_PORT"        "$(DB_PORT)"
	@printf "  %-20s = %s\n" "DB_USER"        "$(DB_USER)"
	@printf "  %-20s = %s\n" "DB_PASSWORD"    "$(DB_PASSWORD)"
	@printf "  %-20s = %s\n" "DB_NAME"        "$(DB_NAME)"
	@printf "  %-20s = %s\n" "DB_SSLMODE"     "$(DB_SSLMODE)"
	@printf "$(_C_BOLD)[Redis]$(_C_RESET)\n"
	@printf "  %-20s = %s\n" "REDIS_HOST"     "$(REDIS_HOST)"
	@printf "  %-20s = %s\n" "REDIS_PORT"     "$(REDIS_PORT)"
	@printf "  %-20s = %s\n" "REDIS_PASSWORD" "$(REDIS_PASSWORD)"
	@printf "$(_C_BOLD)[JWT]$(_C_RESET)\n"
	@printf "  %-20s = %s\n" "JWT_SECRET"     "$(JWT_SECRET)"
	@printf "  %-20s = %s\n" "JWT_EXPIRE"     "$(JWT_EXPIRE)"
	@printf "$(_C_BOLD)[邮件]$(_C_RESET)\n"
	@printf "  %-20s = %s\n" "EMAIL_HOST"     "$(EMAIL_HOST)"
	@printf "  %-20s = %s\n" "EMAIL_PORT"     "$(EMAIL_PORT)"
	@printf "  %-20s = %s\n" "EMAIL_USERNAME" "$(EMAIL_USERNAME)"
	@printf "  %-20s = %s\n" "EMAIL_FROM"     "$(EMAIL_FROM)"
	@printf "$(_C_BOLD)[上传 / CDN]$(_C_RESET)\n"
	@printf "  %-20s = %s\n" "UPLOAD_PATH"    "$(UPLOAD_PATH)"
	@printf "  %-20s = %s\n" "CDN_DOMAIN"     "$(CDN_DOMAIN)"
	@printf "$(_C_BOLD)[Ollama]$(_C_RESET)\n"
	@printf "  %-20s = %s\n" "OLLAMA_BASE_URL" "$(OLLAMA_BASE_URL)"
	@printf "  %-20s = %s\n" "OLLAMA_MODEL"   "$(OLLAMA_MODEL)"
	@printf "$(_C_BOLD)[管理员]$(_C_RESET)\n"
	@printf "  %-20s = %s\n" "ADMIN_EMAIL"    "$(ADMIN_EMAIL)"
	@printf "  %-20s = %s\n" "ADMIN_USERNAME" "$(ADMIN_USERNAME)"
	@printf "  %-20s = %s\n" "ADMIN_PASSWORD" "$(ADMIN_PASSWORD)"
	@printf "\n"

# ── env-check ─────────────────────────────────────────────────────────────────
## 检查必填变量是否已设置
env-check:
	@printf "$(_C_BOLD)[env] 检查必填变量...$(_C_RESET)\n"
	@failed=0; \
	for v in $(_ENV_REQUIRED); do \
	  val=$$(printenv $$v 2>/dev/null); \
	  if [ -z "$$val" ]; then \
	    printf "  $(_C_RED)✗ %-20s 未设置$(_C_RESET)\n" "$$v"; \
	    failed=1; \
	  else \
	    printf "  $(_C_GREEN)✓ %-20s = $$val$(_C_RESET)\n" "$$v"; \
	  fi; \
	done; \
	if [ "$$failed" = "1" ]; then \
	  printf "\n$(_C_RED)[env] ❌ 存在未设置的必填变量，请检查 $(ENV_FILE)$(_C_RESET)\n"; \
	  exit 1; \
	else \
	  printf "\n$(_C_GREEN)[env] ✅ 所有必填变量检查通过$(_C_RESET)\n"; \
	fi

# ── env-validate ──────────────────────────────────────────────────────────────
## 校验变量格式（端口范围、URL 格式等）
env-validate:
	@printf "$(_C_BOLD)[env] 格式校验...$(_C_RESET)\n"
	@failed=0; \
	_check_port() { \
	  local name=$$1 val=$$2; \
	  if [ -n "$$val" ]; then \
	    if ! echo "$$val" | grep -qE '^[0-9]+$$' || [ "$$val" -lt 1 ] || [ "$$val" -gt 65535 ]; then \
	      printf "  $(_C_RED)✗ %-20s = $$val  （应为 1–65535 的整数）$(_C_RESET)\n" "$$name"; \
	      failed=1; \
	    else \
	      printf "  $(_C_GREEN)✓ %-20s = $$val$(_C_RESET)\n" "$$name"; \
	    fi; \
	  fi; \
	}; \
	for port_var in BACKEND_PORT DB_PORT REDIS_PORT EMAIL_PORT HTTP_PORT HTTPS_PORT; do \
	  _check_port $$port_var $$(printenv $$port_var); \
	done; \
	jwt=$$(printenv JWT_SECRET); \
	if [ -n "$$jwt" ] && [ "$${#jwt}" -lt 32 ]; then \
	  printf "  $(_C_RED)✗ %-20s 长度 %d < 32，安全性不足$(_C_RESET)\n" "JWT_SECRET" "$${#jwt}"; \
	  failed=1; \
	else \
	  printf "  $(_C_GREEN)✓ %-20s 长度 %d$(_C_RESET)\n" "JWT_SECRET" "$${#jwt}"; \
	fi; \
	mode=$$(printenv SERVER_MODE); \
	if [ -n "$$mode" ] && ! echo "$$mode" | grep -qE '^(debug|release|test)$$'; then \
	  printf "  $(_C_RED)✗ %-20s = $$mode  （应为 debug/release/test）$(_C_RESET)\n" "SERVER_MODE"; \
	  failed=1; \
	else \
	  printf "  $(_C_GREEN)✓ %-20s = $$mode$(_C_RESET)\n" "SERVER_MODE"; \
	fi; \
	if [ "$$failed" = "1" ]; then \
	  printf "\n$(_C_RED)[env] ❌ 格式校验失败$(_C_RESET)\n"; exit 1; \
	else \
	  printf "\n$(_C_GREEN)[env] ✅ 格式校验通过$(_C_RESET)\n"; \
	fi

# ── env-list-keys ─────────────────────────────────────────────────────────────
## 列出 .env 中所有 KEY 名称
env-list-keys:
	@if [ ! -f "$(ENV_FILE)" ]; then \
	  printf "$(_C_YELLOW)[env] .env 不存在$(_C_RESET)\n"; exit 1; \
	fi
	@printf "$(_C_BOLD)[env] $(ENV_FILE) 中的变量名$(_C_RESET)\n"
	@grep -E '^[A-Za-z_][A-Za-z0-9_]*=' $(ENV_FILE) \
	  | cut -d= -f1 \
	  | while read k; do printf "  %s\n" "$$k"; done

# ── env-get ───────────────────────────────────────────────────────────────────
## 读取单个变量  用法: make env-get KEY=DB_HOST
env-get:
	@if [ -z "$(KEY)" ]; then \
	  printf "$(_C_RED)[env] 用法: make env-get KEY=变量名$(_C_RESET)\n"; exit 1; \
	fi
	@val=$$(printenv $(KEY) 2>/dev/null); \
	if [ -z "$$val" ] && [ -f "$(ENV_FILE)" ]; then \
	  val=$$(grep -E '^$(KEY)=' $(ENV_FILE) | cut -d= -f2-); \
	fi; \
	if [ -z "$$val" ]; then \
	  printf "$(_C_YELLOW)[env] $(KEY) 未设置$(_C_RESET)\n"; \
	else \
	  printf "$(KEY)=$$val\n"; \
	fi

# ── env-set ───────────────────────────────────────────────────────────────────
## 写入或更新单个变量  用法: make env-set KEY=FOO VALUE=bar
env-set:
	@if [ -z "$(KEY)" ] || [ -z "$(VALUE)" ]; then \
	  printf "$(_C_RED)[env] 用法: make env-set KEY=变量名 VALUE=值$(_C_RESET)\n"; exit 1; \
	fi
	@if [ ! -f "$(ENV_FILE)" ]; then \
	  printf "$(_C_YELLOW)[env] .env 不存在，先创建空文件$(_C_RESET)\n"; \
	  touch $(ENV_FILE); \
	fi
	@if grep -qE '^$(KEY)=' $(ENV_FILE) 2>/dev/null; then \
	  sed -i.bak "s|^$(KEY)=.*|$(KEY)=$(VALUE)|" $(ENV_FILE) && rm -f $(ENV_FILE).bak; \
	  printf "$(_C_GREEN)[env] 已更新 $(KEY)=$(VALUE)$(_C_RESET)\n"; \
	else \
	  echo "$(KEY)=$(VALUE)" >> $(ENV_FILE); \
	  printf "$(_C_GREEN)[env] 已追加 $(KEY)=$(VALUE)$(_C_RESET)\n"; \
	fi

# ── env-unset ─────────────────────────────────────────────────────────────────
## 从 .env 中删除单个变量  用法: make env-unset KEY=FOO
env-unset:
	@if [ -z "$(KEY)" ]; then \
	  printf "$(_C_RED)[env] 用法: make env-unset KEY=变量名$(_C_RESET)\n"; exit 1; \
	fi
	@if [ ! -f "$(ENV_FILE)" ]; then \
	  printf "$(_C_YELLOW)[env] .env 不存在$(_C_RESET)\n"; exit 1; \
	fi
	@if grep -qE '^$(KEY)=' $(ENV_FILE); then \
	  sed -i.bak "/^$(KEY)=/d" $(ENV_FILE) && rm -f $(ENV_FILE).bak; \
	  printf "$(_C_GREEN)[env] 已删除 $(KEY)$(_C_RESET)\n"; \
	else \
	  printf "$(_C_YELLOW)[env] $(KEY) 不存在于 .env$(_C_RESET)\n"; \
	fi

# ── env-diff ──────────────────────────────────────────────────────────────────
## 对比 .env 与 .env.example，找出缺失或多余的 KEY
env-diff:
	@if [ ! -f "$(ENV_EXAMPLE)" ]; then \
	  printf "$(_C_YELLOW)[env] 未找到 $(ENV_EXAMPLE)，无法对比$(_C_RESET)\n"; exit 1; \
	fi
	@if [ ! -f "$(ENV_FILE)" ]; then \
	  printf "$(_C_YELLOW)[env] 未找到 $(ENV_FILE)，请先运行 make env-init$(_C_RESET)\n"; exit 1; \
	fi
	@printf "$(_C_BOLD)[env] 对比 .env ↔ .env.example$(_C_RESET)\n\n"
	@example_keys=$$(grep -E '^[A-Za-z_][A-Za-z0-9_]*=' $(ENV_EXAMPLE) | cut -d= -f1 | sort); \
	env_keys=$$(grep -E '^[A-Za-z_][A-Za-z0-9_]*=' $(ENV_FILE) | cut -d= -f1 | sort); \
	missing=$$(comm -23 <(echo "$$example_keys") <(echo "$$env_keys")); \
	extra=$$(comm -13 <(echo "$$example_keys") <(echo "$$env_keys")); \
	if [ -n "$$missing" ]; then \
	  printf "$(_C_RED)在 .env.example 中存在，但 .env 中缺失:$(_C_RESET)\n"; \
	  echo "$$missing" | while read k; do printf "  $(_C_RED)- $$k$(_C_RESET)\n"; done; \
	  printf "\n"; \
	fi; \
	if [ -n "$$extra" ]; then \
	  printf "$(_C_YELLOW)在 .env 中存在，但 .env.example 中没有（自定义变量）:$(_C_RESET)\n"; \
	  echo "$$extra" | while read k; do printf "  $(_C_YELLOW)+ $$k$(_C_RESET)\n"; done; \
	  printf "\n"; \
	fi; \
	if [ -z "$$missing" ] && [ -z "$$extra" ]; then \
	  printf "$(_C_GREEN)✅ .env 与 .env.example 的 KEY 完全一致$(_C_RESET)\n"; \
	fi