# ============================================================
# SQLite 日志查询 Makefile
# 用法: make <target> [参数]
# ============================================================



_SELF_DIR := $(dir $(abspath $(lastword $(MAKEFILE_LIST))))
_ROOT     := $(abspath $(_SELF_DIR)/..)

#@ 数据库路径（可根据实际情况修改）
DB_PATH ?= $(_ROOT)/backend/logs/log.db

# 默认查询条数
LIMIT ?= 100

# 今天日期，与 Go 分表后缀完全一致：logs_YYYYMMDD
TODAY := $(shell date -u +%Y%m%d)

# 今天完整表名，供内部引用
_TABLE_TODAY := logs_$(TODAY)

# 系统 sqlite3 命令
SQLITE3 := sqlite3

# 颜色输出
GREEN  := \033[0;32m
YELLOW := \033[0;33m
RED    := \033[0;31m
NC     := \033[0m


# log.mk 文件开头部分
# _SELF_DIR := $(dir $(abspath $(lastword $(MAKEFILE_LIST))))
# _ROOT     := $(abspath $(_SELF_DIR)/..)

# 自动生帮助生成器
# 必须在任何 include 之前定义自身路径




.PHONY: list-tables query-latest query-errors query-today \
        query-time stats-today search clean-old query

# @列出所有日志分表 
list-tables:
	@echo "$(GREEN)所有日志分表：$(NC)"
	@$(SQLITE3) "$(DB_PATH)" \
		"SELECT name, \
		        (SELECT COUNT(*) FROM sqlite_master sm2 \
		         WHERE sm2.name = 'idx_'||substr(m.name,6)||'_ts') AS has_index \
		 FROM sqlite_master m \
		 WHERE type='table' AND name LIKE 'logs_%' \
		 ORDER BY name DESC;" \
	| awk -F'|' '{printf "  %-20s  index: %s\n", $$1, ($$2=="1"?"yes":"no")}' \
	|| echo "  （未找到任何日志表）"

# @最近 N 条日志（今日表）
query-latest:
	@echo "$(GREEN)[$(_TABLE_TODAY)] 最近 $(LIMIT) 条日志$(NC)"
	@$(SQLITE3) -header -column "$(DB_PATH)" \
		"SELECT timestamp, level, caller, message, fields \
		 FROM $(_TABLE_TODAY) \
		 ORDER BY id DESC \
		 LIMIT $(LIMIT);"

# @最近 N 条错误日志（今日表）
query-errors:
	@echo "$(GREEN)[$(_TABLE_TODAY)] 最近 $(LIMIT) 条 ERROR 日志$(NC)"
	@$(SQLITE3) -header -column "$(DB_PATH)" \
		"SELECT timestamp, level, caller, message, fields \
		 FROM $(_TABLE_TODAY) \
		 WHERE level = 'ERROR' \
		 ORDER BY id DESC \
		 LIMIT $(LIMIT);"

# @按级别查今日日志（LEVEL 默认 INFO）用法: make query-today LEVEL=ERROR LIMIT=50
LEVEL ?= INFO
query-today:
	@echo "$(GREEN)[$(_TABLE_TODAY)] 最近 $(LIMIT) 条 $(LEVEL) 日志$(NC)"
	@$(SQLITE3) -header -column "$(DB_PATH)" \
		"SELECT timestamp, level, caller, message, fields \
		 FROM $(_TABLE_TODAY) \
		 WHERE level = '$(LEVEL)' \
		 ORDER BY id DESC \
		 LIMIT $(LIMIT);"

TABLE ?= $(_TABLE_TODAY)
# @按时间范围查询 
query-time:
ifndef FROM
	$(error 请指定 FROM 参数，例如: make query-time FROM='2026-05-01T08:00:00Z' TO='2026-05-01T09:00:00Z')
endif
ifndef TO
	$(error 请指定 TO 参数，例如: make query-time FROM='2026-05-01T08:00:00Z' TO='2026-05-01T09:00:00Z')
endif
	@echo "$(GREEN)[$(TABLE)] $(FROM) → $(TO)  (最多 $(LIMIT) 条)$(NC)"
	@$(SQLITE3) -header -column "$(DB_PATH)" \
		"SELECT timestamp, level, caller, message, fields \
		 FROM $(TABLE) \
		 WHERE timestamp BETWEEN '$(FROM)' AND '$(TO)' \
		 ORDER BY timestamp ASC \
		 LIMIT $(LIMIT);"

# @今日日志级别统计 
stats-today:
	@echo "$(GREEN)[$(_TABLE_TODAY)] 日志级别统计$(NC)"
	@$(SQLITE3) -header -column "$(DB_PATH)" \
		"SELECT level, \
		        COUNT(*)                                              AS total, \
		        strftime('%H:00', timestamp)                          AS hour_sample \
		 FROM $(_TABLE_TODAY) \
		 GROUP BY level \
		 ORDER BY total DESC;"
	@echo ""
	@echo "$(GREEN)按小时分布（今日）：$(NC)"
	@$(SQLITE3) -header -column "$(DB_PATH)" \
		"SELECT strftime('%H:00', timestamp) AS hour, \
		        level, \
		        COUNT(*) AS count \
		 FROM $(_TABLE_TODAY) \
		 GROUP BY hour, level \
		 ORDER BY hour ASC, count DESC;"

# @在 fields JSON 字段中搜索关键词
search:
ifndef KEYWORD
	$(error 请指定 KEYWORD 参数，例如: make search KEYWORD='user_id')
endif
	@echo "$(GREEN)[$(TABLE)] 搜索 fields 包含 '$(KEYWORD)' 的日志（最多 $(LIMIT) 条）$(NC)"
	@$(SQLITE3) -header -column "$(DB_PATH)" \
		"SELECT timestamp, level, caller, message, fields \
		 FROM $(TABLE) \
		 WHERE fields LIKE '%$(KEYWORD)%' \
		 ORDER BY id DESC \
		 LIMIT $(LIMIT);"

# @删除 N 天前的旧表
clean-old:
ifndef DAYS
	$(error 请指定 DAYS 参数，例如: make clean-old DAYS=30)
endif
	@echo "$(YELLOW)准备删除 $(DAYS) 天前的日志表…$(NC)"
	@cutoff=$$(date -u -d "-$(DAYS) days" +%Y%m%d 2>/dev/null \
	           || date -u -v-$(DAYS)d +%Y%m%d); \
	 tables=$$($(SQLITE3) "$(DB_PATH)" \
	   "SELECT name FROM sqlite_master \
	    WHERE type='table' AND name LIKE 'logs_%' \
	      AND substr(name,6) < '$$cutoff'"); \
	 if [ -z "$$tables" ]; then \
	   echo "  没有需要清理的旧表（cutoff: $$cutoff）"; \
	 else \
	   for t in $$tables; do \
	     echo "  $(RED)删除: $$t$(NC)"; \
	     $(SQLITE3) "$(DB_PATH)" "DROP TABLE IF EXISTS $$t;"; \
	   done; \
	   echo "清理完成"; \
	 fi
# 自动检测 Nginx 日志路径
# 优先检查常见位置，支持 macOS (Homebrew) 和 Linux
NGINX_ACCESS_LOG := $(firstword $(wildcard \
    /var/log/nginx/access.log \
    /usr/local/var/log/nginx/access.log \
    /opt/homebrew/var/log/nginx/access.log \
))

NGINX_ERROR_LOG := $(firstword $(wildcard \
    /var/log/nginx/error.log \
    /usr/local/var/log/nginx/error.log \
    /opt/homebrew/var/log/nginx/error.log \
))

# 检查 Nginx 是否安装/运行（可选）
check-nginx:
	@command -v nginx >/dev/null 2>&1 || (echo "Nginx 未安装，请先安装"; exit 1)
	@pgrep nginx >/dev/null 2>&1 || (echo "Nginx 未运行，请启动 Nginx (e.g., brew services start nginx)"; exit 1)

# @查看 Nginx 访问日志
nginx-access: check-nginx
	@if [ -z "$(NGINX_ACCESS_LOG)" ]; then \
		echo "未找到 Nginx 访问日志，请手动指定路径"; \
		echo "常见路径:"; \
		echo "  macOS (Intel): /usr/local/var/log/nginx/access.log"; \
		echo "  macOS (M1/2):  /opt/homebrew/var/log/nginx/access.log"; \
		echo "  Ubuntu/Debian: /var/log/nginx/access.log"; \
		exit 1; \
	fi
	@tail -f $(NGINX_ACCESS_LOG)

# @查看 Nginx 错误日志
nginx-error: check-nginx
	@if [ -z "$(NGINX_ERROR_LOG)" ]; then \
		echo "未找到 Nginx 错误日志，请手动指定路径"; \
		echo "常见路径:"; \
		echo "  macOS (Intel): /usr/local/var/log/nginx/error.log"; \
		echo "  macOS (M1/2):  /opt/homebrew/var/log/nginx/error.log"; \
		echo "  Ubuntu/Debian: /var/log/nginx/error.log"; \
		exit 1; \
	fi
	@tail -f $(NGINX_ERROR_LOG)

# @执行自定义 SQL
query:
ifndef SQL
	$(error 请指定 SQL 参数，例如: make query SQL="SELECT COUNT(*) FROM $(_TABLE_TODAY)")
endif
	@$(SQLITE3) -header -column "$(DB_PATH)" "$(SQL)"


.PHONY: log-help
# @此帮助信息
log-help:
	@$(MAKE) -s _print_help SELF_MAKEFILE_PATH='$(MAKEFILE_LOG_PATH)'