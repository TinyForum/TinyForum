# ============================================
# Podman Compose 管理命令
# ============================================

.PHONY: podman-up podman-up-logs podman-down podman-down-volumes
.PHONY: podman-restart podman-status podman-logs
.PHONY: podman-logs-backend podman-logs-frontend podman-logs-postgres
.PHONY: podman-shell-backend podman-shell-frontend podman-shell-postgres
.PHONY: podman-build podman-build-backend podman-build-frontend
.PHONY: podman-clean podman-backup-db podman-dev podman-tools
.PHONY: podman-check podman-volume-prune podman-image-prune

# Podman 相关变量
PODMAN_COMPOSE := podman-compose
ENV_FILE := .env

# 检测 podman-compose 是否安装
PODMAN_COMPOSE_CHECK := $(shell command -v podman-compose 2>/dev/null)
PODMAN_CHECK := $(shell command -v podman 2>/dev/null)

# MARK: 构建服务
podman-build:
	@echo "🔨 Building Podman images..."
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) build --no-cache

podman-build-backend:
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) build --no-cache backend

podman-build-frontend:
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) build --no-cache frontend


# MARK: 启动所有服务
podman-up:
	@echo "🐳 Starting all services with Podman..."
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) up -d
	@$(MAKE) podman-status

# 启动服务并查看日志
podman-up-logs:
	@echo "🐳 Starting all services with logs..."
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) up

# 停止所有服务
podman-down:
	@echo "🛑 Stopping all services..."
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) down

# 停止并删除 volumes（会丢失数据）
podman-down-volumes:
	@echo "⚠️  Stopping and removing volumes (data will be lost)..."
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) down -v

# 重启服务
podman-restart:
	@echo "🔄 Restarting all services..."
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) restart
	@$(MAKE) podman-status

# 查看服务状态
podman-status:
	@echo "📊 Podman services status:"
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) ps

# MARK: 查看日志
podman-logs:
	@echo "📝 Tailing all logs..."
	@echo "注意: Podman 远程模式下无法同时查看多个容器日志"
	@echo "请使用以下命令分别查看:"
	@echo "  make podman-logs-backend    - 查看后端日志"
	@echo "  make podman-logs-frontend   - 查看前端日志"
	@echo "  make podman-logs-postgres   - 查看数据库日志"
	@echo ""
	@echo "正在显示所有容器日志（使用 podman-compose）..."
	@-$(PODMAN_COMPOSE) --env-file $(ENV_FILE) logs -f 2>/dev/null || \
	 (echo "❌ 远程模式下多容器日志失败，请使用上述单独命令" && exit 1)

podman-logs-backend:
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) logs -f backend

podman-logs-frontend:
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) logs -f frontend

podman-logs-postgres:
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) logs -f postgres

# 进入容器
podman-shell-backend:
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) exec backend /bin/sh

podman-shell-frontend:
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) exec frontend /bin/sh

podman-shell-postgres:
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) exec postgres psql -U ${DB_USER:-postgres} -d ${DB_NAME:-tiny_forum}


# MARK: 清理 Podman 资源
podman-clean:
	@echo "🧹 Cleaning Podman resources..."
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) down -v --rmi local
	@podman system prune -f

# 只清理悬空卷
podman-volume-prune:
	@echo "🧹 Pruning unused volumes..."
	@podman volume prune -f

# 只清理悬空镜像
podman-image-prune:
	@echo "🧹 Pruning unused images..."
	@podman image prune -f

# 备份数据库
podman-backup-db:
	@echo "💾 Backing up database..."
	@mkdir -p backups
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) exec postgres pg_dump -U ${DB_USER:-postgres} ${DB_NAME:-tiny_forum} > backups/backup_$$(date +%Y%m%d_%H%M%S).sql
	@echo "✅ Backup saved to backups/"

# 启动开发环境（带热重载）
podman-dev:
	@echo "🛠️  Starting development environment..."
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) -f docker-compose.yml -f docker-compose.override.yml up

# 启动工具服务（adminer等）
podman-tools:
	@echo "🔧 Starting tools services..."
	@$(PODMAN_COMPOSE) --env-file $(ENV_FILE) --profile tools up -d

# 检查 Podman 环境
podman-check:
	@echo "🔍 Checking Podman environment..."
	@echo ""
	@echo "Podman version:"
	@if [ -n "$(PODMAN_CHECK)" ]; then \
		podman --version; \
	else \
		echo "❌ Podman not installed"; \
		echo "   Install: brew install podman (macOS)"; \
		echo "   Or: sudo apt install podman (Ubuntu)"; \
		exit 1; \
	fi
	@echo ""
	@echo "Podman-compose version:"
	@if [ -n "$(PODMAN_COMPOSE_CHECK)" ]; then \
		$(PODMAN_COMPOSE) --version; \
	else \
		echo "❌ podman-compose not installed"; \
		echo "   Install: pip install podman-compose"; \
		echo "   Or: brew install podman-compose (macOS)"; \
		exit 1; \
	fi
	@echo ""
	@echo "Podman machine status:"
	@podman machine list
	@echo ""
	@echo "✅ Podman environment check complete"

# MARK: 虚拟机（仅 macOS）
# 初始化 Podman（macOS 需要）
podman-init:
	@echo "🚀 Initializing Podman machine..."
	@if [ "$$(uname)" = "Darwin" ]; then \
		if ! podman machine list | grep -q "Running"; then \
			echo "Creating and starting Podman machine..."; \
			podman machine init --cpus 4 --memory 4096; \
			podman machine start; \
		else \
			echo "Podman machine already running"; \
		fi \
	else \
		echo "Podman machine not needed on Linux"; \
	fi
	@echo "✅ Podman ready"

# 停止 Podman 机器（macOS）
podman-stop-machine:
	@echo "🛑 Stopping Podman machine..."
	@if [ "$$(uname)" = "Darwin" ]; then \
		podman machine stop; \
	else \
		echo "Podman machine not applicable on Linux"; \
	fi

# MARK: 帮助
podman-help:
	@echo "╔══════════════════════════════════════════════════════════════════════╗"
	@echo "║                    🐳 Podman 管理命令                                 ║"
	@echo "╚══════════════════════════════════════════════════════════════════════╝"
	@echo ""
	@echo "快速开始:"
	@echo "  make podman-check          - 检查 Podman 环境"
	@echo "  make podman-init           - 初始化 Podman (macOS)"
	@echo "  make podman-up             - 启动所有服务"
	@echo "  make podman-down           - 停止所有服务"
	@echo ""
	@echo "服务管理:"
	@echo "  make podman-status         - 查看服务状态"
	@echo "  make podman-restart        - 重启所有服务"
	@echo "  make podman-logs           - 查看所有日志"
	@echo "  make podman-dev            - 开发模式（带热重载）"
	@echo ""
	@echo "构建:"
	@echo "  make podman-build          - 重新构建所有镜像"
	@echo "  make podman-build-backend  - 仅构建后端"
	@echo "  make podman-build-frontend - 仅构建前端"
	@echo ""
	@echo "容器操作:"
	@echo "  make podman-shell-backend  - 进入后端容器"
	@echo "  make podman-shell-frontend - 进入前端容器"
	@echo "  make podman-shell-postgres - 进入 PostgreSQL"
	@echo ""
	@echo "清理:"
	@echo "  make podman-clean          - 完整清理（停止+删除）"
	@echo "  make podman-volume-prune   - 清理无用卷"
	@echo "  make podman-image-prune    - 清理无用镜像"
	@echo ""
	@echo "工具:"
	@echo "  make podman-backup-db      - 备份数据库"
	@echo "  make podman-tools          - 启动工具服务（adminer）"
	@echo ""

